# Banco de Dados
DATABASE_URL=postgres://tidocs:suasenha@localhost:5432/tidocs
DB_PASSWORD=suasenha

# JWT
JWT_SECRET=coloque-uma-chave-aleatoria-aqui
JWT_EXPIRES_IN=8h

# IA (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3.5:mini

# CSRF
CSRF_SECRET=coloque-uma-chave-aleatoria-aqui

# Email (SMTP - opcional, sem SMTP as notificações vão apenas para o banco)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tidocs.com

# Frontend URL (usado no link de reset de senha)
FRONTEND_URL=http://localhost:5173

# Servidor
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
